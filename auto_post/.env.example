# ============================================================
# APIキー設定テンプレート
# このファイルをコピーして .env にリネームし、実際の値を入力してください
# cp .env.example .env
# ============================================================

# --- Claude API ---
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- X (Twitter) API ---
# ※ Bearer Tokenだけでは投稿できません。OAuth 1.0a の4つが必要です。
# X Developer Portal (https://developer.twitter.com) でアプリを作成し、
# Read and Write 権限を付与して取得してください。
X_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
X_API_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
X_ACCESS_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
X_ACCESS_TOKEN_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- note.com ---
NOTE_EMAIL=your_email@example.com
NOTE_PASSWORD=your_password_here

# --- Google Sheets ---
# スプレッドシートのID（URLの /d/<ID>/ 部分）
SPREADSHEET_ID=your_spreadsheet_id_here
# 書き込み先のシート名（デフォルト: X投稿管理）
SHEET_NAME=X投稿管理
# サービスアカウントのJSONキーファイルパス（デフォルト: auto_post/google_credentials.json）
GOOGLE_CREDENTIALS_FILE=google_credentials.json
